{
  "name": "debug-stop-all",
  "displayName": "Debug Stop All",
  "description": "Adds a toolbar button and command to stop all active debug sessions at once.",
  "version": "0.1.2",
  "publisher": "UtterDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Utter-Dev/vscode-debug-stop-all"
  },
  "homepage": "https://utterdev.se",
  "bugs": {
    "url": "https://github.com/Utter-Dev/vscode-debug-stop-all/issues"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "icon": "icons/extension-icon.png",
  "keywords": [
    "debug",
    "stop",
    "terminate",
    "sessions",
    "toolbar",
    "compound",
    "multiple",
    "launch"
  ],
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debug-stop-all.stopAll",
        "title": "Stop All",
        "category": "Debug",
        "icon": {
          "light": "icons/stop-all-light.svg",
          "dark": "icons/stop-all-dark.svg"
        }
      }
    ],
    "menus": {
      "debug/toolBar": [
        {
          "command": "debug-stop-all.stopAll",
          "when": "inDebugMode",
          "group": "navigation@60"
        }
      ],
      "commandPalette": [
        {
          "command": "debug-stop-all.stopAll",
          "when": "inDebugMode"
        }
      ]
    },
    "keybindings": [
      {
        "command": "debug-stop-all.stopAll",
        "key": "ctrl+shift+f11",
        "mac": "cmd+shift+f11",
        "when": "inDebugMode"
      }
    ]
  },
  "scripts": {
    "compile": "tsc",
    "watch": "tsc -watch",
    "package": "npm run compile && vsce package",
    "install-ext": "npm run package && code --install-extension debug-stop-all-0.1.2.vsix --force"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.0.0"
  }
}
